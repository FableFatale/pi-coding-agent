# Pi Memory - 环境配置示例
# 复制为 .env 并填入实际值

# ============================================================
# L1 Working Memory (Redis)
# ============================================================
L1_REDIS_HOST=localhost
L1_REDIS_PORT=6379
L1_REDIS_DB=0
L1_REDIS_PASSWORD=
L1_TTL=3600

# ============================================================
# L2 Episodic Memory (PostgreSQL)
# ============================================================
L2_PG_HOST=localhost
L2_PG_PORT=5432
L2_PG_DATABASE=pimemory
L2_PG_USER=postgres
L2_PG_PASSWORD=your_password_here
L2_VECTOR_DIM=768

# ============================================================
# L3 Semantic Memory (Pinecone)
# ============================================================
L3_PINECONE_API_KEY=your_pinecone_api_key_here
L3_PINECONE_ENV=us-east-1
L3_PINECONE_INDEX=pi-skills
L3_PINECONE_CLOUD=aws
